# iDebKu OJK Configuration
HEADLESS=true
LOG_LEVEL=INFO
LOG_FORMAT=console

# Browser settings
BROWSER_TIMEOUT=30

# HTTP settings
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Captcha settings
CAPTCHA_MAX_ATTEMPTS=3

# Telegram Notification (optional)
TELEGRAM_BOT_TOKEN=
