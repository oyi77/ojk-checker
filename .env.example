# Email Notification (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# Scheduler
SCHEDULER_TIMEZONE=Asia/Jakarta
